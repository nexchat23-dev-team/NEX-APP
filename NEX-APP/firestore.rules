rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function isOwner(userId) {
      return isAuthenticated() && uid() == userId;
    }

    function isGroupMember(groupId) {
      return isAuthenticated() &&
             exists(/databases/{database}/documents/groups/$(groupId)) &&
             uid() in get(/databases/{database}/documents/groups/$(groupId)).data.members;
    }

    function isGroupAdmin(groupId) {
      return isAuthenticated() &&
             exists(/databases/{database}/documents/groups/$(groupId)) &&
             uid() in get(/databases/{database}/documents/groups/$(groupId)).data.admins;
    }

    function isSuperAdmin() {
      return isAuthenticated() && uid() in ['demonalexander526@gmail.com'];
    }

    // ============================================================
    // USERS
    // ============================================================
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && request.resource.data.uid == uid;
      allow update: if isOwner(uid);
      allow delete: if false;
    }

    // ============================================================
    // GROUPS
    // ============================================================
    match /groups/{groupId} {
      allow create: if isAuthenticated() && uid() == request.resource.data.creatorId;
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() in resource.data.admins;
      allow delete: if isAuthenticated() && uid() == resource.data.creatorId;

      match /messages/{messageId} {
        allow create: if isAuthenticated() && isGroupMember(groupId);
        allow read: if isAuthenticated() && isGroupMember(groupId);
        allow update, delete: if isAuthenticated() && (uid() == resource.data.senderId || isGroupAdmin(groupId));
      }

      match /documents/{documentId} {
        allow create, read: if isAuthenticated() && isGroupMember(groupId);
        allow update, delete: if isAuthenticated() && (uid() == resource.data.uploadedBy || isGroupAdmin(groupId));
      }

      match /sharedMedia/{mediaId} {
        allow create, read: if isAuthenticated() && isGroupMember(groupId);
        allow update, delete: if isAuthenticated() && (uid() == resource.data.senderId || isGroupAdmin(groupId));
      }
    }

    // ============================================================
    // GROUP MESSAGES (TOP-LEVEL)
    // ============================================================
    match /groupMessages/{messageId} {
      allow create: if isAuthenticated() && isGroupMember(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update, delete: if isAuthenticated() && (uid() == resource.data.senderId || isGroupAdmin(resource.data.groupId));
    }

    // ============================================================
    // DIRECT MESSAGES
    // ============================================================
    match /messages/{messageId} {
      allow create: if isAuthenticated() && request.resource.data.from == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.from || uid() == resource.data.to);
      allow update: if isAuthenticated() && uid() == resource.data.from;
      allow delete: if isAuthenticated() && (uid() == resource.data.from || uid() == resource.data.to);
    }

    // ============================================================
    // TYPING STATUS (Real-time typing indicators)
    // ============================================================
    match /typingStatus/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // STATUSES
    // ============================================================
    match /statuses/{statusId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow update, delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // ADVERTISEMENTS
    // ============================================================
    match /advertisements/{adId} {
      allow read: if isAuthenticated() && resource.data.status == 'active';
      allow create: if isAuthenticated() && request.resource.data.sellerUID == uid();
      allow update: if isAuthenticated() && uid() == resource.data.sellerUID;
      allow delete: if isAuthenticated() && uid() == resource.data.sellerUID;
    }

    // ============================================================
    // SHARED MEDIA
    // ============================================================
    match /sharedMedia/{mediaId} {
      allow create: if isAuthenticated() && request.resource.data.senderId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.senderId || uid() == resource.data.recipientId);
      allow delete: if isAuthenticated() && (uid() == resource.data.senderId || uid() == resource.data.recipientId);
    }

    // ============================================================
    // OFFLINE MESSAGE QUEUE
    // ============================================================
    match /offlineMessageQueue/{queueId} {
      allow create, read, update, delete: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // MESSAGE ACTIVITY
    // ============================================================
    match /messageActivity/{activityId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if false;
    }

    // ============================================================
    // REPORTS
    // ============================================================
    match /reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reportedBy == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.reportedBy || isSuperAdmin());
      allow update, delete: if isSuperAdmin();
    }

    // ============================================================
    // CHAT REQUESTS (Friend/Chat Requests)
    // ============================================================
    match /chatRequests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.from == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.from || uid() == resource.data.to);
      allow update: if isAuthenticated() && uid() == resource.data.to;
      allow delete: if isAuthenticated() && (uid() == resource.data.from || uid() == resource.data.to);
    }

    // ============================================================
    // USER SECURITY (Security/Privacy Settings)
    // ============================================================
    match /userSecurity/{uid} {
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow write: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // GROUP JOIN REQUESTS
    // ============================================================
    match /groupJoinRequests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isGroupAdmin(resource.data.groupId));
      allow update: if isAuthenticated() && isGroupAdmin(resource.data.groupId);
      allow delete: if isAuthenticated() && (uid() == resource.data.userId || isGroupAdmin(resource.data.groupId));
    }

    // ============================================================
    // BLOCKED USERS
    // ============================================================
    match /blockedUsers/{blockId} {
      allow create, read, update, delete: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // PRESENCE
    // ============================================================
    match /presence/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // ============================================================
    // USER BACKGROUNDS
    // ============================================================
    match /userBackgrounds/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // DIRECT MESSAGE BACKGROUNDS
    // ============================================================
    match /directMessageBackgrounds/{docId} {
      allow read, write: if isAuthenticated() && (uid() == docId.split('_')[0] || uid() == docId.split('_')[1]);
    }

    // ============================================================
    // GROUP BACKGROUNDS
    // ============================================================
    match /groupBackgrounds/{groupId} {
      allow read, write: if isAuthenticated() && isGroupMember(groupId);
    }

    // ============================================================
    // CALLS
    // ============================================================
    match /calls/{callId} {
      allow create: if isAuthenticated() && request.resource.data.callerId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);
      allow update: if isAuthenticated() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);
      allow delete: if isAuthenticated() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);

      match /iceCandidates/{candidateId} {
        allow create: if isAuthenticated() && request.resource.data.from == uid();
        allow read: if isAuthenticated() && (uid() == get(/databases/$(database)/documents/calls/$(callId)).data.callerId || uid() == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
        allow delete: if isAuthenticated() && request.resource.data.from == uid();
      }

      match /sdp/{sdpId} {
        allow create: if isAuthenticated() && request.resource.data.from == uid();
        allow read: if isAuthenticated() && (uid() == get(/databases/$(database)/documents/calls/$(callId)).data.callerId || uid() == get(/databases/$(database)/documents/calls/$(callId)).data.receiverId);
        allow update: if isAuthenticated() && request.resource.data.from == uid();
      }
    }

    // ============================================================
    // CALL HISTORY
    // ============================================================
    match /callHistory/{historyId} {
      allow create: if isAuthenticated() && (request.resource.data.callerId == uid() || request.resource.data.receiverId == uid());
      allow read: if isAuthenticated() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);
      allow update: if isAuthenticated() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);
      allow delete: if isAuthenticated() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);
    }

    // ============================================================
    // GROUP CALLS
    // ============================================================
    match /groupCalls/{groupCallId} {
      allow create: if isAuthenticated() && isGroupMember(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update: if isAuthenticated() && uid() == resource.data.initiatorId;
      allow delete: if isAuthenticated() && uid() == resource.data.initiatorId;

      match /participants/{participantId} {
        allow create: if isAuthenticated() && isGroupMember(get(/databases/$(database)/documents/groupCalls/$(groupCallId)).data.groupId);
        allow read: if isAuthenticated() && isGroupMember(get(/databases/$(database)/documents/groupCalls/$(groupCallId)).data.groupId);
        allow update: if isAuthenticated() && uid() == resource.data.userId;
        allow delete: if isAuthenticated() && (uid() == resource.data.userId || uid() == get(/databases/$(database)/documents/groupCalls/$(groupCallId)).data.initiatorId);
      }
    }

    // ============================================================
    // NOTIFICATIONS
    // ============================================================
    match /notifications/{notificationId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // USER SETTINGS
    // ============================================================
    match /userSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // APP CONFIG
    // ============================================================
    match /appConfig/{configId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // SYSTEM LOGS
    // ============================================================
    match /systemLogs/{logId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================================
    // ANALYTICS
    // ============================================================
    match /analytics/{analyticsId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================================
    // ANNOUNCEMENTS
    // ============================================================
    match /announcements/{announcementId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // AI CHATS (ChronoX AI Chat History)
    // ============================================================
    match /aiChats/{chatId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // TERMINAL COMMANDS
    // ============================================================
    match /terminalCommands/{cmdId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if false;
    }

    // ============================================================
    // TOKEN STATISTICS
    // ============================================================
    match /tokenStatistics/{statId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================================
    // MAINTENANCE
    // ============================================================
    match /maintenance/{maintenanceId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // FEATURE FLAGS
    // ============================================================
    match /featureFlags/{flagId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // RATE LIMITS
    // ============================================================
    match /rateLimits/{limitId} {
      allow read, write: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // USER SESSIONS
    // ============================================================
    match /userSessions/{sessionId} {
      allow read, write: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // DEVICE TOKENS
    // ============================================================
    match /deviceTokens/{tokenId} {
      allow read, write: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // EMOJI REACTIONS
    // ============================================================
    match /emojiReactions/{reactionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // MESSAGE THREADS
    // ============================================================
    match /messageThreads/{threadId} {
      allow create: if isAuthenticated() && uid() in request.resource.data.participants;
      allow read: if isAuthenticated() && uid() in resource.data.participants;
      allow update: if isAuthenticated() && uid() in resource.data.participants;
      allow delete: if isAuthenticated() && uid() in resource.data.participants;
    }

    // ============================================================
    // GROUP POLLS
    // ============================================================
    match /groupPolls/{pollId} {
      allow create: if isAuthenticated() && isGroupMember(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update: if isAuthenticated() && uid() == resource.data.createdBy;
      allow delete: if isAuthenticated() && (uid() == resource.data.createdBy || isGroupAdmin(resource.data.groupId));
    }

    // ============================================================
    // POLL VOTES
    // ============================================================
    match /pollVotes/{voteId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // GROUP EVENTS
    // ============================================================
    match /groupEvents/{eventId} {
      allow create: if isAuthenticated() && isGroupMember(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update: if isAuthenticated() && uid() == resource.data.createdBy;
      allow delete: if isAuthenticated() && (uid() == resource.data.createdBy || isGroupAdmin(resource.data.groupId));
    }

    // ============================================================
    // EVENT ATTENDEES
    // ============================================================
    match /eventAttendees/{attendeeId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // GROUP ANNOUNCEMENTS
    // ============================================================
    match /groupAnnouncements/{announcementId} {
      allow create: if isAuthenticated() && isGroupAdmin(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update, delete: if isAuthenticated() && uid() == resource.data.createdBy;
    }

    // ============================================================
    // USER ACHIEVEMENTS
    // ============================================================
    match /userAchievements/{achievementId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if false;
    }

    // ============================================================
    // LEADERBOARDS
    // ============================================================
    match /leaderboards/{leaderboardId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // USER STATS
    // ============================================================
    match /userStats/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // ============================================================
    // GROUP STATS
    // ============================================================
    match /groupStats/{groupId} {
      allow read: if isGroupMember(groupId);
      allow write: if isGroupAdmin(groupId);
    }

    // ============================================================
    // SYSTEM STATS
    // ============================================================
    match /systemStats/{statId} {
      allow read, write: if isSuperAdmin();
    }

    // ============================================================
    // USER SECURITY (Security/Privacy Settings)
    // ============================================================
    match /userSecurity/{uid} {
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow write: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // ERROR LOGS
    // ============================================================
    match /errorLogs/{errorId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isSuperAdmin();
    }

    // ============================================================
    // DEBUG LOGS
    // ============================================================
    match /debugLogs/{debugId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isSuperAdmin();
    }

    // ============================================================
    // PERFORMANCE METRICS
    // ============================================================
    match /performanceMetrics/{metricId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isSuperAdmin();
    }

    // ============================================================
    // API USAGE LOGS
    // ============================================================
    match /apiUsageLogs/{logId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isSuperAdmin();
    }

    // ============================================================
    // SECURITY AUDIT LOGS
    // ============================================================
    match /securityAuditLogs/{auditId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isSuperAdmin();
    }

    // ============================================================
    // USER FEEDBACK
    // ============================================================
    match /userFeedback/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read, update, delete: if isSuperAdmin();
    }

    // ============================================================
    // SUPPORT TICKETS
    // ============================================================
    match /supportTickets/{ticketId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // BETA FEATURES
    // ============================================================
    match /betaFeatures/{featureId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // EXPERIMENTAL FEATURES
    // ============================================================
    match /experimentalFeatures/{featureId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // A/B TESTING
    // ============================================================
    match /abTesting/{testId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // USER PREFERENCES
    // ============================================================
    match /userPreferences/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // GROUP PREFERENCES
    // ============================================================
    match /groupPreferences/{groupId} {
      allow read: if isGroupMember(groupId);
      allow write: if isGroupAdmin(groupId);
    }

    // ============================================================
    // THEME SETTINGS
    // ============================================================
    match /themeSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // NOTIFICATION SETTINGS
    // ============================================================
    match /notificationSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // PRIVACY SETTINGS
    // ============================================================
    match /privacySettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // SECURITY SETTINGS
    // ============================================================
    match /securitySettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // ACCOUNT SETTINGS
    // ============================================================
    match /accountSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // PROFILE SETTINGS
    // ============================================================
    match /profileSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // CHAT SETTINGS
    // ============================================================
    match /chatSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // MEDIA SETTINGS
    // ============================================================
    match /mediaSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // CALL SETTINGS
    // ============================================================
    match /callSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // GROUP SETTINGS
    // ============================================================
    match /groupSettings/{groupId} {
      allow read: if isGroupMember(groupId);
      allow write: if isGroupAdmin(groupId);
    }

    // ============================================================
    // MARKETPLACE SETTINGS
    // ============================================================
    match /marketplaceSettings/{uid} {
      allow read, write: if isOwner(uid);
    }

    // ============================================================
    // PAYMENT HISTORY
    // ============================================================
    match /paymentHistory/{paymentId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if false;
    }

    // ============================================================
    // TOKEN GIFTS
    // ============================================================
    match /tokenGifts/{giftId} {
      allow create: if isAuthenticated() && request.resource.data.senderId == uid();
      allow read: if isAuthenticated() && (resource.data.senderId == uid() || resource.data.recipientId == uid() || isSuperAdmin());
      allow update: if isAuthenticated() && (resource.data.senderId == uid() || resource.data.recipientId == uid() || isSuperAdmin());
      allow delete: if isSuperAdmin();
    }

    // ============================================================
    // TOKEN TRANSACTIONS
    // ============================================================
    match /tokenTransactions/{transactionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update, delete: if false;
    }

    // ============================================================
    // TOKEN BALANCES (User wallet balance)
    // ============================================================
    match /tokenBalances/{userId} {
      allow read: if isAuthenticated() && (uid() == userId || isSuperAdmin());
      allow create: if isAuthenticated() && uid() == userId;
      allow update: if isAuthenticated() && (uid() == userId || isSuperAdmin());
      allow delete: if false;
    }

    // ============================================================
    // PROMO CODES
    // ============================================================
    match /promoCodes/{codeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // ============================================================
    // PROMO REDEMPTIONS (Track who used which promo)
    // ============================================================
    match /promoRedemptions/{redemptionId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update, delete: if false;
    }

    // ============================================================
    // TOKEN PACKAGES (Marketplace packs for sale)
    // ============================================================
    match /tokenPackages/{packageId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // ============================================================
    // ORDERS (Token package purchases)
    // ============================================================
    match /orders/{orderId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow delete: if false;
    }

    // ============================================================
    // BETTING
    // ============================================================
    match /bets/{betId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ============================================================
    // BETTING RESULTS
    // ============================================================
    match /bettingResults/{resultId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isSuperAdmin();
    }

    // ============================================================
    // USER BET HISTORY
    // ============================================================
    match /betHistory/{historyId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update, delete: if false;
    }

    // ============================================================
    // WALLET TRANSACTIONS
    // ============================================================
    match /walletTransactions/{walletId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    // ============================================================
    // SUBSCRIPTIONS
    // ============================================================
    match /subscriptions/{subscriptionId} {
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow write: if isAuthenticated() && request.resource.data.userId == uid();
    }

    // ============================================================
    // PREMIUM FEATURES
    // ============================================================
    match /premiumFeatures/{featureId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // USER BADGES
    // ============================================================
    match /userBadges/{badgeId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if false;
    }

    // ============================================================
    // GROUP BADGES
    // ============================================================
    match /groupBadges/{badgeId} {
      allow create: if isAuthenticated() && isGroupAdmin(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update, delete: if false;
    }

    // ============================================================
    // CHALLENGES
    // ============================================================
    match /challenges/{challengeId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // USER CHALLENGES
    // ============================================================
    match /userChallenges/{challengeId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // GROUP CHALLENGES
    // ============================================================
    match /groupChallenges/{challengeId} {
      allow create: if isAuthenticated() && isGroupMember(request.resource.data.groupId);
      allow read: if isAuthenticated() && isGroupMember(resource.data.groupId);
      allow update: if isAuthenticated() && uid() == resource.data.createdBy;
      allow delete: if isAuthenticated() && uid() == resource.data.createdBy;
    }

    // ============================================================
    // CLANS (Gaming Squads)
    // ============================================================
    match /clans/{clanId} {
      allow create: if isAuthenticated() && request.resource.data.createdBy == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (uid() in resource.data.leaders || uid() in resource.data.admins);
      allow delete: if isAuthenticated() && uid() == resource.data.createdBy;
    }

    // ============================================================
    // CLAN INVITES
    // ============================================================
    match /clanInvites/{inviteId} {
      allow create: if isAuthenticated() && request.resource.data.invitedBy == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.userId || uid() == resource.data.invitedBy);
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && (uid() == resource.data.userId || uid() == resource.data.invitedBy);
    }

    // ============================================================
    // GAMING CLIPS
    // ============================================================
    match /clips/{clipId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
      allow delete: if isAuthenticated() && (uid() == resource.data.userId || isSuperAdmin());
    }

    // ============================================================
    // COMPETITIONS
    // ============================================================
    match /competitions/{competitionId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // TOURNAMENTS
    // ============================================================
    match /tournaments/{tournamentId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // GAMIFICATION
    // ============================================================
    match /gamification/{gamificationId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // REWARDS
    // ============================================================
    match /rewards/{rewardId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if false;
    }

    // ============================================================
    // USER LEVELS
    // ============================================================
    match /userLevels/{uid} {
      allow read: if isAuthenticated();
      allow write: if isOwner(uid);
    }

    // ============================================================
    // USER PROGRESS
    // ============================================================
    match /userProgress/{progressId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // SOCIAL FEATURES
    // ============================================================
    match /socialFeatures/{featureId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // FRIEND REQUESTS
    // ============================================================
    match /friendRequests/{requestId} {
      allow create: if isAuthenticated() && request.resource.data.from == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.from || uid() == resource.data.to);
      allow update: if isAuthenticated() && uid() == resource.data.to;
      allow delete: if isAuthenticated() && (uid() == resource.data.from || uid() == resource.data.to);
    }

    // ============================================================
    // FRIENDS
    // ============================================================
    match /friends/{friendId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update: if isAuthenticated() && uid() == resource.data.userId;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // FOLLOWERS
    // ============================================================
    match /followers/{followId} {
      allow create: if isAuthenticated() && request.resource.data.followerId == uid();
      allow read: if isAuthenticated() && (uid() == resource.data.followerId || uid() == resource.data.followingId);
      allow update: if false;
      allow delete: if isAuthenticated() && uid() == resource.data.followerId;
    }

    // ============================================================
    // SOCIAL POSTS
    // ============================================================
    match /socialPosts/{postId} {
      allow create: if isAuthenticated() && request.resource.data.authorId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.authorId;
      allow delete: if isAuthenticated() && uid() == resource.data.authorId;
    }

    // ============================================================
    // POST LIKES
    // ============================================================
    match /postLikes/{likeId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // POST COMMENTS
    // ============================================================
    match /postComments/{commentId} {
      allow create: if isAuthenticated() && request.resource.data.authorId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.authorId;
      allow delete: if isAuthenticated() && uid() == resource.data.authorId;
    }

    // ============================================================
    // STORIES
    // ============================================================
    match /stories/{storyId} {
      allow create: if isAuthenticated() && request.resource.data.authorId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.authorId;
      allow delete: if isAuthenticated() && uid() == resource.data.authorId;
    }

    // ============================================================
    // STORY VIEWS
    // ============================================================
    match /storyViews/{viewId} {
      allow create: if isAuthenticated() && request.resource.data.viewerId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.viewerId;
      allow update, delete: if false;
    }

    // ============================================================
    // LIVE STREAMS
    // ============================================================
    match /liveStreams/{streamId} {
      allow create: if isAuthenticated() && request.resource.data.streamerId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.streamerId;
      allow delete: if isAuthenticated() && uid() == resource.data.streamerId;
    }

    // ============================================================
    // STREAM VIEWERS
    // ============================================================
    match /streamViewers/{viewerId} {
      allow create: if isAuthenticated() && request.resource.data.viewerId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.viewerId;
      allow update: if isAuthenticated() && uid() == resource.data.viewerId;
      allow delete: if isAuthenticated() && uid() == resource.data.viewerId;
    }

    // ============================================================
    // STREAM CHAT
    // ============================================================
    match /streamChat/{messageId} {
      allow create: if isAuthenticated() && request.resource.data.senderId == uid();
      allow read: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated() && uid() == resource.data.senderId;
    }

    // ============================================================
    // VIDEOS
    // ============================================================
    match /videos/{videoId} {
      allow create: if isAuthenticated() && request.resource.data.uploaderId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.uploaderId;
      allow delete: if isAuthenticated() && uid() == resource.data.uploaderId;
    }

    // ============================================================
    // VIDEO COMMENTS
    // ============================================================
    match /videoComments/{commentId} {
      allow create: if isAuthenticated() && request.resource.data.authorId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.authorId;
      allow delete: if isAuthenticated() && uid() == resource.data.authorId;
    }

    // ============================================================
    // VIDEO LIKES
    // ============================================================
    match /videoLikes/{likeId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated() && uid() == resource.data.userId;
    }

    // ============================================================
    // PLAYLISTS
    // ============================================================
    match /playlists/{playlistId} {
      allow create: if isAuthenticated() && request.resource.data.creatorId == uid();
      allow read: if isAuthenticated();
      allow update: if isAuthenticated() && uid() == resource.data.creatorId;
      allow delete: if isAuthenticated() && uid() == resource.data.creatorId;
    }

    // ============================================================
    // PLAYLIST VIDEOS
    // ============================================================
    match /playlistVideos/{videoId} {
      allow create: if isAuthenticated() && request.resource.data.addedBy == uid();
      allow read: if isAuthenticated();
      allow update: if false;
      allow delete: if isAuthenticated() && uid() == resource.data.addedBy;
    }

    // ============================================================
    // CONTENT MODERATION
    // ============================================================
    match /contentModeration/{moderationId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // SPAM REPORTS
    // ============================================================
    match /spamReports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reporterId == uid();
      allow read, update, delete: if isSuperAdmin();
    }

    // ============================================================
    // CONTENT FILTERS
    // ============================================================
    match /contentFilters/{filterId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // USER VERIFICATION
    // ============================================================
    match /userVerification/{verificationId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if isSuperAdmin();
    }

    // ============================================================
    // TRUST SCORES
    // ============================================================
    match /trustScores/{uid} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ============================================================
    // REPUTATION
    // ============================================================
    match /reputation/{reputationId} {
      allow create: if isAuthenticated() && request.resource.data.userId == uid();
      allow read: if isAuthenticated() && uid() == resource.data.userId;
      allow update, delete: if false;
    }

    // ============================================================
    // DEFAULT DENY
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }

  }
}