rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════════════
    function isSignedIn() {
      return request.auth != null;
    }
    function uid() {
      return request.auth.uid;
    }
    function isAdmin() {
      return request.auth.token.email == 'admin@nexchat.com';
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // USERS COLLECTION - User profiles and token balances
    // ═══════════════════════════════════════════════════════════════════════════════
    match /users/{userId} {
      // Users may read their own profile; public flag allows public reads
      allow read: if isSignedIn() && (uid() == userId || (resource.data.public == true));
      // Only the authenticated user may create/update/delete their own profile
      allow create: if isSignedIn() && uid() == userId;
      allow update, delete: if isSignedIn() && uid() == userId;
    }

    // TOKEN BALANCES - User token holdings
    // Structure: /tokenBalances/{userId} - fields: balance, transactions[]
    match /tokenBalances/{userId} {
      allow read: if isSignedIn() && uid() == userId;
      allow create: if isSignedIn() && uid() == userId;
      allow update: if isSignedIn() && uid() == userId;
      allow delete: if false; // Balances cannot be deleted
    }

    // MARKETPLACE ORDERS - Token purchases
    // Structure: /orders/{orderId} - fields: userId, packType, amount, status, createdAt
    match /orders/{orderId} {
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow read: if isSignedIn() && (uid() == resource.data.userId || isAdmin());
      allow update: if isSignedIn() && (uid() == resource.data.userId || isAdmin());
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // CONVERSATIONS - Chat and Group Chat
    // ═══════════════════════════════════════════════════════════════════════════════
    match /conversations/{convId} {
      // Create: signed-in user that creates the conversation must be included as a member
      allow create: if isSignedIn()
                    && uid() == request.resource.data.createdBy
                    && (uid() in request.resource.data.members);

      // Read: only members can read conversation metadata
      allow read: if isSignedIn() && (uid() in resource.data.members);

      // Update/delete: restricted to admins listed on the conversation doc
      allow update, delete: if isSignedIn() && (uid() in resource.data.admins);

      // MEMBERS subcollection
      match /members/{memberId} {
        allow read: if isSignedIn() && (uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.members);
        allow create: if isSignedIn() && (uid() == memberId || uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.admins);
        allow update: if isSignedIn() && (uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.admins);
        allow delete: if isSignedIn() && (uid() == memberId || uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.admins);
      }

      // MESSAGES subcollection
      match /messages/{messageId} {
        allow read: if isSignedIn() && (uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.members);
        allow create: if isSignedIn()
                      && uid() == request.resource.data.senderId
                      && (uid() in get(/databases/$(database)/documents/conversations/$(convId)).data.members);
        allow update, delete: if false; // Immutable messages
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // DIRECT MESSAGES - User to user chat
    // ═══════════════════════════════════════════════════════════════════════════════
    match /directMessages/{dmId} {
      allow create: if isSignedIn() && uid() == request.resource.data.senderId 
                    && (uid() == request.resource.data.recipientId || uid() == request.resource.data.senderId);
      allow read: if isSignedIn() && (uid() == resource.data.senderId || uid() == resource.data.recipientId);
      allow update, delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // STATUS UPDATES - WhatsApp-style status stories
    // ═══════════════════════════════════════════════════════════════════════════════
    match /statusUpdates/{statusId} {
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow read: if isSignedIn() && (
        uid() == resource.data.userId || 
        uid() in resource.data.visibleTo[]
      );
      allow delete: if isSignedIn() && uid() == resource.data.userId;
      allow update: if false; // Status updates are immutable
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // CALLS - Audio/Video call signaling
    // ═══════════════════════════════════════════════════════════════════════════════
    match /calls/{callId} {
      allow create: if isSignedIn()
                    && uid() == request.resource.data.callerId
                    && (request.resource.data.participants is list)
                    && (uid() in request.resource.data.participants);
      allow read, update, delete: if isSignedIn() && (uid() in resource.data.participants);
    }

    // CALL HISTORY - Record of past calls
    // Structure: /callHistory/{recordId} - fields: callerId, receiverId, type, duration, timestamp
    match /callHistory/{recordId} {
      allow create: if isSignedIn() && uid() == request.resource.data.callerId;
      allow read: if isSignedIn() && (uid() == resource.data.callerId || uid() == resource.data.receiverId);
      allow delete: if isSignedIn() && uid() == resource.data.callerId;
      allow update: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // ANNOUNCEMENTS - Admin broadcasts (NEW)
    // ═══════════════════════════════════════════════════════════════════════════════
    match /announcements/{announcementId} {
      // Anyone signed in can read announcements
      allow read: if isSignedIn();
      // Only admins can create/update/delete
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // ADVERTISEMENTS - Promos, sales, events (NEW)
    // ═══════════════════════════════════════════════════════════════════════════════
    match /advertisements/{adId} {
      // Anyone signed in can read ads
      allow read: if isSignedIn();
      // Only admins can manage advertisements
      allow create, update, delete: if isSignedIn() && isAdmin();
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // GAMING HUB - Games, clans, squads, clips (NEW)
    // ═══════════════════════════════════════════════════════════════════════════════
    
    // Game scores/leaderboard
    match /gameScores/{gameId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow update: if isSignedIn() && (uid() == resource.data.userId || isAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    // Clans/teams
    match /clans/{clanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (uid() in resource.data.adminIds[]);
      allow delete: if isSignedIn() && isAdmin();
      
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && uid() == memberId;
        allow delete: if isSignedIn() && (uid() in get(/databases/$(database)/documents/clans/$(clanId)).data.adminIds[]);
      }
    }

    // Gaming squads
    match /squads/{squadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && uid() == request.resource.data.leaderId;
      allow update, delete: if isSignedIn() && uid() == resource.data.leaderId;
      
      match /members/{memberId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && uid() == memberId;
        allow delete: if isSignedIn() && (uid() == memberId || uid() == get(/databases/$(database)/documents/squads/$(squadId)).data.leaderId);
      }
    }

    // Game clips/videos
    match /gameClips/{clipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow update: if isSignedIn() && uid() == resource.data.userId;
      allow delete: if isSignedIn() && (uid() == resource.data.userId || isAdmin());
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // AI CHAT - Conversation history with NEX AI (NEW)
    // ═══════════════════════════════════════════════════════════════════════════════
    match /aiConversations/{conversationId} {
      allow read: if isSignedIn() && uid() == resource.data.userId;
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow update: if isSignedIn() && uid() == resource.data.userId;
      allow delete: if isSignedIn() && uid() == resource.data.userId;
      
      match /messages/{messageId} {
        allow read: if isSignedIn() && uid() == get(/databases/$(database)/documents/aiConversations/$(conversationId)).data.userId;
        allow create: if isSignedIn() && uid() == get(/databases/$(database)/documents/aiConversations/$(conversationId)).data.userId;
        allow read, write: if isSignedIn() && uid() == get(/databases/$(database)/documents/aiConversations/$(conversationId)).data.userId;
      }
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // BETTING/GAMES - Game sessions and transactions (NEW)
    // ═══════════════════════════════════════════════════════════════════════════════
    match /gameSessions/{sessionId} {
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow read: if isSignedIn() && (uid() == resource.data.userId || isAdmin());
      allow update: if isSignedIn() && isAdmin(); // Only admins can settle games
      allow delete: if false;
    }

    // Betting history
    match /bettingHistory/{betId} {
      allow create: if isSignedIn() && uid() == request.resource.data.userId;
      allow read: if isSignedIn() && (uid() == resource.data.userId || isAdmin());
      allow delete: if false;
    }

    // ═══════════════════════════════════════════════════════════════════════════════
    // DEFAULT DENY - Secure everything else
    // ═══════════════════════════════════════════════════════════════════════════════
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// Notes / rationale:
// - This rule set enforces authentication and membership checks for conversation metadata, membership management,
//   message creation, and call signaling. Memberships are modeled with a members subcollection so that users can
//   remove themselves (leave) while admins can add/remove others.
// - WhatsApp reference: WhatsApp maintains server-side group metadata (admins, members) and enforces admin actions;
//   end-to-end encryption and key management are handled client-side using the Signal Protocol. Firestore rules
//   cannot provide end-to-end encryption — E2EE must be implemented in the client. See WhatsApp security overview:
//   https://www.whatsapp.com/security/ and Signal Protocol docs: https://signal.org/docs/ for background.
